# ===========================================
# Terraform Variables
# ===========================================
# Copy this file to terraform.tfvars:
#   cp terraform.tfvars.example terraform.tfvars
#
# Then fill in your values.
# ===========================================

# AWS Region
aws_region  = "us-east-1"
environment = "dev"

# Your existing VPC and Subnet IDs (REQUIRED)
# Find these with:
#   aws ec2 describe-vpcs --query 'Vpcs[*].[VpcId,Tags[?Key==`Name`].Value|[0]]' --output table
#   aws ec2 describe-subnets --query 'Subnets[*].[SubnetId,VpcId]' --output table
vpc_id    = "vpc-xxxxxxxxx"
subnet_id = "subnet-xxxxxxxxx"

# EC2 Configuration
instance_type = "t3.micro"
instance_name = "my-ec2-instance"

# Security - Restrict SSH in production!
# Example: ["203.0.113.0/32"] for single IP
allowed_ssh_cidrs = ["0.0.0.0/0"]
